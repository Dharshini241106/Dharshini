class Solution(object):
    def shortestPalindrome(self, s):
        """
        :type s: str
        :rtype: str
        """
        if not s:
            return ""
        
        # 1. Create a combined string: s + special_char + reverse(s)
        # The special character '#' ensures we don't match across the boundary
        combined = s + "#" + s[::-1]
        
        # 2. Build the KMP lookup table (pi table) for the combined string
        n = len(combined)
        pi = [0] * n
        for i in range(1, n):
            j = pi[i-1]
            while j > 0 and combined[i] != combined[j]:
                j = pi[j-1]
            if combined[i] == combined[j]:
                j += 1
            pi[i] = j
            
        # 3. The last value in the pi table is the length of the 
        # longest palindromic prefix of the original string 's'
        longest_palindromic_prefix_len = pi[-1]
        
        # 4. Take the part of 's' that isn't in the palindrome, 
        # reverse it, and add it to the front
        suffix_to_add = s[longest_palindromic_prefix_len:]
        return suffix_to_add[::-1] + s
