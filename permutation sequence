import math

class Solution(object):
    def getPermutation(self, n, k):
        # Create a list of available numbers: [1, 2, 3, ..., n]
        nums = [str(i) for i in range(1, n + 1)]
        # Factorials pre-calculation or use math.factorial
        fact = math.factorial(n)
        
        k -= 1  # Convert to 0-indexing
        res = []
        
        for i in range(n, 0, -1):
            # How many permutations for the remaining (i-1) digits
            fact //= i
            # Find index of the digit to pick
            idx = k // fact
            res.append(nums.pop(idx))
            # Update k for the next position
            k %= fact
            
        return "".join(res)
